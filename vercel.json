{
    "functions": {
        "*.php": {
            "runtime": "vercel-php@0.7.2"
        },
        "auth/*.php": {
            "runtime": "vercel-php@0.7.2"
        },
        "admin/*.php": {
            "runtime": "vercel-php@0.7.2"
        },
        "owner/*.php": {
            "runtime": "vercel-php@0.7.2"
        },
        "petugas/*.php": {
            "runtime": "vercel-php@0.7.2"
        }
    },
    "routes": [
        {
            "src": "/(assets/.*)",
            "dest": "/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/$1"
        }
    ]
}